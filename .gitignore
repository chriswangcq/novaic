# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ------------------------------------------------------------
# Local configuration
# ------------------------------------------------------------
.env
.env.local
*.local.yaml
*.local.yml
secrets.yaml
secrets.yml

# ------------------------------------------------------------
# Project specific
# ------------------------------------------------------------

# Frontend / Node.js
node_modules/
.vite/
dist/

# Rust build artifacts
target/

# VM assets (too large for git)
vm/images/
vm/iso/
runtime/images/*.qcow2
runtime/firmware/*.fd
runtime/firmware/*.fd.bak
runtime/.ubuntu-vm.pid
packages/novaic-vm/firmware/*.fd

# External repos (use separately)
paper/benchmarks/

# User data directory (contains personal data)
# Note: The actual ~/.nb-cc directory is outside the repo
paper/benchmarks/data/
*.db
*.sqlite
*.sqlite3

# Log files
logs/
*.log

# Model files (too large for git)
models/
*.gguf
*.bin
*.safetensors

# Temporary files
tmp/
temp/
*.tmp

# Artifacts generated by agent
artifacts/

# Neo4j data
neo4j/

# Vector store data
vectors/
chroma/

# ERA / Sandbox
.era/
*.img
rootfs/

# Documentation and paper (internal only)
docs/
paper/

# Build artifacts
*.dmg
.cursor/

# Tauri bundled resources (copied during build)
novaic-app/src-tauri/resources/novaic-gateway/
