+def _require_positive_generation(value: Any, owner: str) -> int:
+    if value is None:
+        raise ValueError(f"generation is required for {owner}")
+    if isinstance(value, bool):
+        raise ValueError(f"positive generation is required for {owner}")
+    try:
+        generation = int(value)
+    except (TypeError, ValueError) as exc:
+        raise ValueError(f"positive generation is required for {owner}") from exc
+    if generation < 1:
+        raise ValueError(f"positive generation is required for {owner}")
+    return generation
+
+
+def _require_non_negative_generation(value: Any, owner: str) -> int:
+    if value is None:
+        raise ValueError(f"generation is required for {owner}")
+    if isinstance(value, bool):
+        raise ValueError(f"non-negative generation is required for {owner}")
+    try:
+        generation = int(value)
+    except (TypeError, ValueError) as exc:
+        raise ValueError(f"non-negative generation is required for {owner}") from exc
+    if generation < 0:
+        raise ValueError(f"non-negative generation is required for {owner}")
+    return generation
+
+
+def _runtime_generation_for_status(
+    status: SessionRuntimeStatus,
+    value: Any,
+    owner: str,
+) -> int:
+    if status is SessionRuntimeStatus.NO_ACTIVE:
+        if value is None:
+            return 0
+        return _require_non_negative_generation(value, owner)
+    return _require_positive_generation(value, owner)
+
+
