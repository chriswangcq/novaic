# NB-CC Agent environment variables
# Copy to `agent/.env` and fill your values.

# Agent server
NBCC_HOST=0.0.0.0
NBCC_PORT=8080
NBCC_DEBUG=false

# LLM (OpenAI-compatible) API
NBCC_LLM_API_BASE=https://api.nuwaapi.com
NBCC_LLM_API_KEY=your-api-key-here

# Defaults
NBCC_DEFAULT_MODEL=gpt-5
NBCC_MAX_TOKENS=4096

# Workspace paths
NBCC_WORK_DIR=/tmp/nb-cc-workspace
NBCC_UPLOAD_DIR=/tmp/nb-cc-uploads


