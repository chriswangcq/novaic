# NB-CC Cloud environment variables
# Copy to `cloud/.env` and fill your values.

# Cloud server
NBCC_HOST=0.0.0.0
NBCC_PORT=8000
NBCC_DEBUG=false

# Database
NBCC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nbcc

# JWT (set a strong secret in production; if omitted, an ephemeral dev secret is generated)
NBCC_JWT_SECRET=change-me
NBCC_JWT_ALGORITHM=HS256
NBCC_JWT_EXPIRE_DAYS=7

# LLM proxy (OpenAI-compatible)
NBCC_LLM_API_BASE=https://api.nuwaapi.com/v1
NBCC_LLM_API_KEY=your-api-key-here
NBCC_DEFAULT_MODEL=gpt-4o
NBCC_MAX_TOKENS=4096


