# Root Docker context allowlist for API backend images.
#
# Keep this file narrow: the desktop app, Rust build outputs, archives, and
# historical docs make the repository far too large to send as a Docker build
# context for backend service images.

**

!.dockerignore
!docker/
!docker/**

!Entangled/
!Entangled/packages/
!Entangled/packages/server-python/
!Entangled/packages/server-python/**

!novaic-agent-runtime/
!novaic-agent-runtime/**
!novaic-blob-service/
!novaic-blob-service/**
!novaic-business/
!novaic-business/**
!novaic-common/
!novaic-common/**
!novaic-cortex/
!novaic-cortex/**
!novaic-device/
!novaic-device/**
!novaic-gateway/
!novaic-gateway/**
!novaic-logicalfs/
!novaic-logicalfs/**
!novaic-release-controller/
!novaic-release-controller/**
!novaic-sandbox-sdk/
!novaic-sandbox-sdk/**
!novaic-sandbox-service/
!novaic-sandbox-service/**

**/.git
**/.venv
**/venv
**/__pycache__
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/node_modules
**/target
**/dist
**/build
**/artifacts
**/*.pyc
**/*.pyo
**/*.db
**/*.sqlite
**/*.sqlite3
docs-archive/
archive/
