# novaic-quic-service 生产环境变量
# 复制为 .env 或 systemd Environment 使用

# Gateway URL（relay 鉴权调用 validate-device）
GATEWAY_URL=https://api.gradievo.com

# Relay QUIC 监听端口（生产 443，需 root 或 setcap）
RELAY_PORT=443

# STUN UDP 端口（RFC 5389 标准 3478）
STUN_PORT=3478

# Relay TLS 证书（Let's Encrypt 等）
# 生产必填，否则用自签名（仅开发）
RELAY_TLS_CERT_PATH=/etc/letsencrypt/live/relay.gradievo.com/fullchain.pem
RELAY_TLS_KEY_PATH=/etc/letsencrypt/live/relay.gradievo.com/privkey.pem

# 日志级别（可选）
# RUST_LOG=info
