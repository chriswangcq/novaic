# Gateway 启动所需环境变量
# 部署时复制到服务器 /opt/novaic/jwt_secret.env 并填写 JWT_SECRET
# 此 example 进 git；jwt_secret.env 仅存在于服务器，不进 git

JWT_SECRET=<openssl rand -hex 32 生成>

# P2P Relay 兜底（relay-request 返回给手机），可选
# 未设置时 restart_gw.sh 使用默认 https://relay.gradievo.com/p2p/relay
export RELAY_URL=https://relay.gradievo.com/p2p/relay

# 前端 OTA 热更新 CDN URL（可选）
# 未设置或空时 /api/config/frontend 返回默认 https://relay.gradievo.com/resource/frontend/v0.3.0/
# 必须为 https:// 开头；需与 novaic-app capabilities 的 remote.urls 域名一致（当前为 relay.gradievo.com）
export FRONTEND_CDN_URL=https://relay.gradievo.com/resource/frontend/v0.3.0/
export FRONTEND_VERSION=0.3.0

# TURN 服务器共享密钥（coturn static-auth-secret）
# 与 relay.gradievo.com 上 /etc/turnserver.conf 的 static-auth-secret 一致
# 未设置时 /api/turn/credentials 只返回 STUN（不含 TURN 凭证）
export TURN_SECRET=<openssl rand -hex 32 生成>
export TURN_SERVER=relay.gradievo.com
export TURN_PORT=3478
