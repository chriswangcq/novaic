{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://novaic.dev/contracts/schema/storage-artifact.v1.schema.json",
  "title": "StorageArtifactV1",
  "type": "object",
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "artifact_kind": {
      "type": "string",
      "enum": ["file-service", "tool-result"]
    },
    "file_url": {
      "type": "string"
    },
    "checksum_sha256": {
      "type": "string"
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "artifact_id",
    "artifact_kind",
    "file_url",
    "checksum_sha256",
    "size_bytes",
    "created_at"
  ],
  "additionalProperties": false
}
