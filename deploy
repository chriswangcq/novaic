#!/bin/bash
# NovAIC 统一部署入口
# 用法: ./deploy <target> [options]

set -e

# ── 配置 ──────────────────────────────────────────────────────────────────────
REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
RELAY_HOST="47.243.221.45"
RELAY_PORT="52222"
RELAY_SSH="ssh -p $RELAY_PORT root@$RELAY_HOST"
API_HOST="root@api.gradievo.com"
API_SSH="ssh $API_HOST"
VERSION="${2:-0.3.0}"
SERVICES_DIR="/opt/novaic/services"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}▸ $1${NC}"; }
ok()    { echo -e "${GREEN}✓ $1${NC}"; }
warn()  { echo -e "${YELLOW}⚠ $1${NC}"; }
fail()  { echo -e "${RED}✗ $1${NC}"; exit 1; }

# ── 通用：部署 Python 服务到 api.gradievo.com ─────────────────────────────────
# 用法: deploy_service <service-name> <process-pattern> <start-command>
deploy_service() {
  local name="$1"
  local proc_pattern="$2"
  local start_cmd="$3"
  local local_dir="$REPO_ROOT/$name"

  [ -d "$local_dir" ] || fail "本地目录不存在: $local_dir"

  info "部署 $name 到 api.gradievo.com"

  info "同步代码..."
  rsync -avz --exclude '.git' --exclude '__pycache__' --exclude '*.pyc' \
    --exclude 'target' --exclude '.venv' --exclude 'node_modules' \
    -e ssh "$local_dir/" "$API_HOST:$SERVICES_DIR/$name/" || fail "rsync 失败"

  info "重启 $name..."
  $API_SSH "pkill -f '$proc_pattern' 2>/dev/null || true; sleep 1; cd $SERVICES_DIR/$name && $start_cmd" || fail "重启失败"

  ok "$name 已部署"
}

# ── 各服务部署 ────────────────────────────────────────────────────────────────

deploy_frontend() {
  local ver="${1:-$VERSION}"
  info "部署前端 OTA (v${ver})"
  cd "$REPO_ROOT/novaic-app"
  info "构建前端..."
  VITE_BASE="/resource/frontend/v${ver}/" npm run build || fail "前端构建失败"
  info "上传到 relay..."
  $RELAY_SSH "mkdir -p /opt/novaic/static/v${ver}"
  rsync -avz --delete -e "ssh -p $RELAY_PORT" dist/ root@$RELAY_HOST:/opt/novaic/static/v${ver}/ || fail "rsync 失败"
  ok "前端 v${ver} 已部署到 https://relay.gradievo.com/resource/frontend/v${ver}/"
}

deploy_gateway() {
  info "部署 Gateway 到 api.gradievo.com"
  cd "$REPO_ROOT/novaic-gateway"
  info "同步代码..."
  rsync -avz --exclude '.git' --exclude '__pycache__' --exclude '*.pyc' \
    -e ssh . $API_HOST:$SERVICES_DIR/novaic-gateway/ || fail "rsync 失败"
  info "重启 Gateway..."
  $API_SSH 'bash /opt/novaic/restart_gw.sh' || fail "重启失败"
  sleep 2
  $API_SSH 'ss -tlnp | grep 19999' && ok "Gateway 已部署 (port 19999)" || warn "端口 19999 未监听"
}

deploy_runtime() {
  deploy_service "novaic-agent-runtime" "main_novaic.py" \
    "nohup .venv/bin/python main_novaic.py queue-service >> /opt/novaic/data/logs/runtime-\$(date +%Y%m%d).log 2>&1 &"
  info "注意: runtime 包含多个 worker (task-worker×4, saga-worker×2, watchdog, health, scheduler)"
  info "如需全部重启，请运行: ./deploy runtime-all"
}

deploy_runtime_all() {
  info "重启 Agent Runtime 全部进程"
  cd "$REPO_ROOT/novaic-agent-runtime"

  info "同步代码..."
  rsync -avz --exclude '.git' --exclude '__pycache__' --exclude '*.pyc' \
    --exclude 'target' --exclude '.venv' \
    -e ssh . $API_HOST:$SERVICES_DIR/novaic-agent-runtime/ || fail "rsync 失败"

  info "停止所有 runtime 进程..."
  $API_SSH "pkill -f 'main_novaic.py' 2>/dev/null || true; sleep 2"

  info "启动 queue-service + workers..."
  $API_SSH "cd $SERVICES_DIR/novaic-agent-runtime && \
    nohup .venv/bin/python main_novaic.py queue-service >> /opt/novaic/data/logs/runtime-\$(date +%Y%m%d).log 2>&1 & \
    nohup .venv/bin/python main_novaic.py watchdog >> /opt/novaic/data/logs/runtime-\$(date +%Y%m%d).log 2>&1 & \
    nohup .venv/bin/python main_novaic.py health >> /opt/novaic/data/logs/runtime-\$(date +%Y%m%d).log 2>&1 & \
    nohup .venv/bin/python main_novaic.py scheduler >> /opt/novaic/data/logs/runtime-\$(date +%Y%m%d).log 2>&1 & \
    for i in 1 2 3 4; do nohup .venv/bin/python main_novaic.py task-worker >> /opt/novaic/data/logs/runtime-\$(date +%Y%m%d).log 2>&1 & done; \
    for i in 1 2; do nohup .venv/bin/python main_novaic.py saga-worker >> /opt/novaic/data/logs/runtime-\$(date +%Y%m%d).log 2>&1 & done"

  sleep 2
  local count=$($API_SSH "pgrep -f main_novaic.py | wc -l")
  ok "Agent Runtime 已启动 ($count 个进程)"
}

deploy_orchestrator() {
  deploy_service "novaic-runtime-orchestrator" "main_runtime_orchestrator.py" \
    "nohup .venv/bin/python main_runtime_orchestrator.py --host 127.0.0.1 --port 19993 >> /opt/novaic/data/logs/orchestrator-\$(date +%Y%m%d).log 2>&1 &"
}

deploy_tools() {
  deploy_service "novaic-tools-server" "main_tools.py" \
    "nohup .venv/bin/python main_tools.py --host 127.0.0.1 --port 19998 >> /opt/novaic/data/logs/tools-\$(date +%Y%m%d).log 2>&1 &"
}

deploy_storage_a() {
  deploy_service "novaic-storage-a" "main_file_service.py" \
    "nohup .venv/bin/python main_file_service.py --host 127.0.0.1 --port 19995 >> /opt/novaic/data/logs/storage-a-\$(date +%Y%m%d).log 2>&1 &"
}

deploy_storage_b() {
  deploy_service "novaic-storage-b" "main_tool_result_service.py" \
    "nohup .venv/bin/python main_tool_result_service.py --host 127.0.0.1 --port 19994 >> /opt/novaic/data/logs/storage-b-\$(date +%Y%m%d).log 2>&1 &"
}

deploy_relay() {
  info "部署 novaic-quic-service 到 relay"
  cd "$REPO_ROOT/novaic-quic-service"
  info "推送代码到 GitHub..."
  git add -A && git diff --cached --quiet || git commit -m "deploy: $(date +%Y-%m-%d)"
  git push origin main 2>/dev/null || true
  info "服务器拉取并编译..."
  $RELAY_SSH 'cd /opt/novaic/novaic-quic-service && git pull origin main && cargo build --release && systemctl stop novaic-quic-service && cp target/release/novaic-quic-service ./ && systemctl start novaic-quic-service' || fail "编译或重启失败"
  $RELAY_SSH 'systemctl is-active novaic-quic-service' && ok "Relay 已部署" || warn "服务未运行"
}

deploy_ios() {
  info "构建 iOS IPA 并安装"
  cd "$REPO_ROOT/novaic-app"
  npm run tauri ios build -- --export-method debugging || fail "iOS 构建失败"
  local IPA="src-tauri/gen/apple/build/arm64/NovAIC.ipa"
  [ -f "$IPA" ] || fail "IPA 不存在: $IPA"
  local DEVICE=$(xcrun devicectl list devices 2>/dev/null | awk '/connected/ && !/Simulator/ {for(i=1;i<=NF;i++) if($i~/^[0-9A-F]{8}-/) {print $i;break}}' | head -1)
  if [ -z "$DEVICE" ]; then warn "未找到设备，IPA 在: $IPA"
  else xcrun devicectl device install app --device "$DEVICE" "$IPA" && ok "iOS 已安装" || fail "安装失败"; fi
}

deploy_desktop() {
  info "构建 macOS 桌面应用"
  cd "$REPO_ROOT/novaic-app"
  npm run tauri:build -- --bundles app || fail "桌面构建失败"
  ok "桌面应用: src-tauri/target/release/bundle/macos/NovAIC.app"
}

# ── 聚合命令 ──────────────────────────────────────────────────────────────────

deploy_services() {
  info "部署全部后端服务到 api.gradievo.com"
  deploy_gateway
  deploy_runtime_all
  deploy_orchestrator
  deploy_tools
  deploy_storage_a
  deploy_storage_b
  echo ""
  ok "全部后端服务已部署！"
}

deploy_all() {
  deploy_frontend "$1"
  deploy_services
  deploy_relay
  deploy_ios
  deploy_desktop
  echo ""
  ok "🎉 全部部署完成！"
}

# ── 状态检查 ──────────────────────────────────────────────────────────────────

check_status() {
  info "检查 api.gradievo.com 服务状态"
  echo ""
  $API_SSH 'echo "  PID   | PORT  | SERVICE"
    echo "  ------|-------|--------"
    ss -tlnp 2>/dev/null | grep -oP "127.0.0.1:\K\d+" | sort -n | while read port; do
      pid=$(ss -tlnp | grep ":$port " | grep -oP "pid=\K\d+")
      case $port in
        19993) svc="orchestrator" ;;
        19994) svc="storage-b" ;;
        19995) svc="storage-a" ;;
        19998) svc="tools-server" ;;
        19999) svc="gateway" ;;
        *)     svc="unknown" ;;
      esac
      printf "  %-6s| %-6s| %s\n" "$pid" "$port" "$svc"
    done
    echo ""
    runtime_count=$(pgrep -f main_novaic.py | wc -l)
    echo "  Agent Runtime: $runtime_count 进程"'
  echo ""
  info "检查 relay 服务状态"
  $RELAY_SSH 'systemctl is-active novaic-quic-service && echo "  Relay: ✓ running" || echo "  Relay: ✗ stopped"'
}

# ── 主入口 ────────────────────────────────────────────────────────────────────

show_help() {
  echo ""
  echo -e "${CYAN}NovAIC 部署工具${NC}"
  echo ""
  echo "用法: ./deploy <target> [version]"
  echo ""
  echo -e "${CYAN}客户端:${NC}"
  echo "  frontend [ver]    部署前端 OTA (默认 v0.3.0)"
  echo "  ios               构建并安装 iOS IPA"
  echo "  desktop           构建 macOS 桌面应用"
  echo ""
  echo -e "${CYAN}后端服务 (api.gradievo.com):${NC}"
  echo "  gateway           Gateway          (port 19999)"
  echo "  runtime           Agent Runtime    (queue-service only)"
  echo "  runtime-all       Agent Runtime    (全部 worker)"
  echo "  orchestrator      Runtime Orchestrator (port 19993)"
  echo "  tools             Tools Server     (port 19998)"
  echo "  storage-a         Storage A        (port 19995)"
  echo "  storage-b         Storage B        (port 19994)"
  echo ""
  echo -e "${CYAN}基础设施 (relay):${NC}"
  echo "  relay             QUIC/Relay 服务"
  echo ""
  echo -e "${CYAN}聚合:${NC}"
  echo "  services          部署全部后端服务"
  echo "  all [ver]         部署全部（前端+后端+客户端）"
  echo "  status            检查所有服务状态"
  echo ""
}

case "${1}" in
  frontend)     deploy_frontend "$2" ;;
  gateway)      deploy_gateway ;;
  runtime)      deploy_runtime ;;
  runtime-all)  deploy_runtime_all ;;
  orchestrator) deploy_orchestrator ;;
  tools)        deploy_tools ;;
  storage-a)    deploy_storage_a ;;
  storage-b)    deploy_storage_b ;;
  relay)        deploy_relay ;;
  ios)          deploy_ios ;;
  desktop)      deploy_desktop ;;
  services)     deploy_services ;;
  all)          deploy_all "$2" ;;
  status)       check_status ;;
  *)            show_help ;;
esac
