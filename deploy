#!/bin/bash
# NovAIC 统一部署入口
# 用法: ./deploy <target> [options]
#
# 代码同步: 本地 rsync → 服务器
# 进程管理: 服务器端 start.sh（不在本地 nohup）

set -e

# ── 配置 ──────────────────────────────────────────────────────────────────────
REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
RELAY_HOST="47.243.221.45"
RELAY_PORT="22"
RELAY_SSH="ssh -p $RELAY_PORT root@$RELAY_HOST"
API_HOST="root@api.gradievo.com"
API_SSH="ssh $API_HOST"
FACTORY_HOST="root@newapi.gradievo.com"
FACTORY_SSH="ssh $FACTORY_HOST"
VERSION="${2:-0.3.0}"
SERVICES_DIR="/opt/novaic/services"
RSYNC_EXCLUDE="--exclude .git --exclude __pycache__ --exclude .pytest_cache --exclude .mypy_cache --exclude '*.pyc' --exclude target --exclude build --exclude dist --exclude artifacts --exclude .venv --exclude node_modules --exclude '*.db'"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}▸ $1${NC}"; }
ok()    { echo -e "${GREEN}✓ $1${NC}"; }
warn()  { echo -e "${YELLOW}⚠ $1${NC}"; }
fail()  { echo -e "${RED}✗ $1${NC}"; exit 1; }

# ── 通用：同步代码到服务器（不重启） ──────────────────────────────────────────
rsync_service() {
  local name="$1"
  local local_dir="$REPO_ROOT/$name"
  [ -d "$local_dir" ] || fail "本地目录不存在: $local_dir"
  info "同步 $name..."
  # Clean stale generated artifacts first. These are excluded from rsync, so
  # --delete cannot remove old build outputs by itself.
  $API_SSH "find $SERVICES_DIR/$name -type d \( -name __pycache__ -o -name .pytest_cache -o -name .mypy_cache -o -name build -o -name dist -o -name artifacts \) -exec rm -rf {} + 2>/dev/null" || true
  rsync -avzL --delete $RSYNC_EXCLUDE -e ssh "$local_dir/" "$API_HOST:$SERVICES_DIR/$name/" || fail "rsync $name 失败"
}

install_service_requirements() {
  local name="$1"
  [ -f "$REPO_ROOT/$name/requirements.txt" ] || return 0
  info "安装 $name 依赖..."
  $API_SSH "set -e; cd $SERVICES_DIR/$name; \
    rm -rf .venv; \
    python3 -m venv .venv; \
    .venv/bin/python -m pip install -q -r requirements.txt" \
    || fail "$name pip install 失败"
}

# ── 客户端部署 ────────────────────────────────────────────────────────────────

deploy_frontend() {
  local ver="${1:-$VERSION}"
  info "部署前端 OTA (v${ver})"
  cd "$REPO_ROOT/novaic-app"
  info "构建前端..."
  VITE_BASE="/resource/frontend/v${ver}/" npm run build || fail "前端构建失败"
  info "上传到 relay..."
  $RELAY_SSH "mkdir -p /opt/novaic/static/v${ver}"
  rsync -avz --delete -e "ssh -p $RELAY_PORT" dist/ root@$RELAY_HOST:/opt/novaic/static/v${ver}/ || fail "rsync 失败"
  ok "前端 v${ver} 已部署到 https://relay.gradievo.com/resource/frontend/v${ver}/"
}

deploy_ios() {
  info "构建 iOS IPA 并安装"
  cd "$REPO_ROOT/novaic-app"
  # Fix: Xcode 26.x beta ships MacOSX26.2.sdk, causing aws-lc-sys (cc-rs) to
  # use -mmacosx-version-min=26.2 for host code, which fails compilation.
  # Force a sane deployment target for the host (macOS) build.
  export MACOSX_DEPLOYMENT_TARGET="15.0"
  npm run tauri ios build -- --export-method debugging || fail "iOS 构建失败"
  local IPA="src-tauri/gen/apple/build/arm64/ByClaw.ipa"
  [ -f "$IPA" ] || fail "IPA 不存在: $IPA"
  local DEVICE=$(xcrun devicectl list devices 2>/dev/null | awk '/connected/ && !/Simulator/ {for(i=1;i<=NF;i++) if($i~/^[0-9A-F]{8}-/) {print $i;break}}' | head -1)
  if [ -z "$DEVICE" ]; then warn "未找到设备，IPA 在: $IPA"
  else xcrun devicectl device install app --device "$DEVICE" "$IPA" && ok "iOS 已安装" || fail "安装失败"; fi
}

deploy_desktop() {
  info "构建 macOS 桌面应用"
  cd "$REPO_ROOT/novaic-app"
  npm run tauri:build -- --bundles app || fail "桌面构建失败"
  info "安装到 /Applications"
  rm -rf /Applications/ByClaw.app
  cp -R src-tauri/target/release/bundle/macos/ByClaw.app /Applications/
  ok "桌面应用已部署到 /Applications/ByClaw.app"
}

# ── 通用：同步 start.sh + 重启 ────────────────────────────────────────────────
sync_start_sh() {
  info "同步 start.sh..."
  scp -q "$REPO_ROOT/scripts/start.sh" "$API_HOST:/opt/novaic/start.sh"
}

restart_all() {
  info "重启全部后端服务（通过 start.sh）..."
  $API_SSH 'bash /opt/novaic/start.sh --stop && bash /opt/novaic/start.sh' || fail "重启失败"
}

# ── 后端服务部署（rsync + 服务器端 start.sh 管理进程） ────────────────────────

deploy_gateway() {
  info "部署 Gateway + Business + Device + Entangled"
  rsync_service "novaic-common"
  rsync_service "novaic-gateway"
  rsync_service "novaic-business"
  rsync_service "novaic-device"
  rsync_service "Entangled"
  sync_start_sh
  restart_all
  ok "Gateway 全栈已部署（全部服务已重启）"
}

deploy_single_service() {
  local name="$1"
  rsync_service "novaic-common"
  rsync_service "$name"
  install_service_requirements "$name"
  sync_start_sh
  restart_all
  ok "$name 已部署（全部服务已重启）"
}

# Business / Device 共用 Gateway 的 venv，不需要单独 pip install
deploy_shared_venv_service() {
  local name="$1"
  rsync_service "novaic-common"
  rsync_service "$name"
  sync_start_sh
  restart_all
  ok "$name 已部署（全部服务已重启）"
}

deploy_services() {
  info "部署全部后端服务到 api.gradievo.com"
  echo ""

  # novaic-common 必须先同步（gateway/business/device/runtime 的 common/ 是 symlink）
  for svc in novaic-common novaic-gateway novaic-business novaic-device \
             novaic-agent-runtime novaic-blob-service novaic-cortex Entangled; do
    rsync_service "$svc"
  done

  for svc in novaic-blob-service novaic-cortex novaic-agent-runtime; do
    install_service_requirements "$svc"
  done

  sync_start_sh
  echo ""
  restart_all

  echo ""
  ok "全部后端服务已部署！"
}

deploy_relay() {
  info "部署 novaic-quic-service 到 relay"
  cd "$REPO_ROOT/novaic-quic-service"
  info "同步代码到服务器..."
  rsync -avz -e "ssh -p $RELAY_PORT" --exclude target --exclude .git . root@$RELAY_HOST:/opt/novaic/novaic-quic-service/ || fail "rsync 失败"
  info "服务器拉取并编译..."
  $RELAY_SSH 'export PATH="$HOME/.cargo/bin:$PATH" && cd /opt/novaic/novaic-quic-service && cargo build --release && systemctl stop novaic-quic-service && cp target/release/novaic-quic-service ./ && systemctl start novaic-quic-service' || fail "编译或重启失败"
  $RELAY_SSH 'systemctl is-active novaic-quic-service' && ok "Relay 已部署" || warn "服务未运行"
}

deploy_factory() {
  info "部署 LLM Factory 到 newapi.gradievo.com"
  local local_dir="$REPO_ROOT/novaic-llm-factory"
  [ -d "$local_dir" ] || fail "本地目录不存在: $local_dir"
  info "同步代码..."
  rsync -avz $RSYNC_EXCLUDE -e ssh "$local_dir/" "$FACTORY_HOST:/opt/novaic/llm-factory/" || fail "rsync 失败"
  info "安装依赖 + 重启..."
  $FACTORY_SSH 'cd /opt/novaic/llm-factory && source .venv/bin/activate && pip install -q -r requirements.txt && systemctl restart llm-factory' || fail "重启失败"
  sleep 2
  $FACTORY_SSH 'curl -sf http://127.0.0.1:19990/health' && ok "LLM Factory 已部署 (newapi.gradievo.com)" || fail "健康检查失败"
}

# ── 聚合命令 ──────────────────────────────────────────────────────────────────

deploy_all() {
  deploy_frontend "$1"
  deploy_services
  deploy_relay
  deploy_ios
  deploy_desktop
  echo ""
  ok "🎉 全部部署完成！"
}

# ── 状态检查 ──────────────────────────────────────────────────────────────────

check_status() {
  info "检查 api.gradievo.com 服务状态"
  echo ""
  $API_SSH '
    echo "  PORT  | PID    | SERVICE"
    echo "  ------|--------|--------"
    for port in 19900 19999 19998 19993 19997 19995 19996; do
      pid=$(ss -tlnp 2>/dev/null | grep ":$port " | grep -oP "pid=\K\d+" | head -1)
      case $port in
        19900) svc="entangled" ;;
        19999) svc="gateway" ;;
        19998) svc="business" ;;
        19993) svc="device" ;;
        19997) svc="queue-svc" ;;
        19995) svc="blob-service" ;;
        19996) svc="cortex" ;;
      esac
      if [ -n "$pid" ]; then
        printf "  %-6s| %-7s| ✓ %s\n" "$port" "$pid" "$svc"
      else
        printf "  %-6s| %-7s| ✗ %s (DOWN)\n" "$port" "-" "$svc"
      fi
    done
    echo ""
    worker_count=$(pgrep -f "main_novaic.py" 2>/dev/null | wc -l)
    queue_count=$(pgrep -cf "main_novaic.py queue-service" 2>/dev/null || echo 0)
    echo "  Workers: $((worker_count - queue_count)) 进程 (health, scheduler, task-workers, saga-workers)"
  '
  echo ""
  info "检查 relay 服务状态"
  $RELAY_SSH 'systemctl is-active novaic-quic-service && echo "  Relay: ✓ running" || echo "  Relay: ✗ stopped"'
}

# ── 运维：重置 Gateway 用户登录密码（api.gradievo.com 上 gateway.db） ─────────
# 新密码通过管道传入远端 Python，避免出现在 ssh 命令行参数里。
# 用法:
#   ./deploy reset-password 7334381@qq.com
#   （交互输入两次新密码，至少 8 位）
# 非交互（仅本机脚本/CI，注意 shell 历史）:
#   NOVAIC_DEPLOY_NEW_PASSWORD='YourPass12' ./deploy reset-password 7334381@qq.com
reset_user_password() {
  local email="${2:-}"
  [ -n "$email" ] || fail "用法: ./deploy reset-password <email>"
  local pass="${NOVAIC_DEPLOY_NEW_PASSWORD:-}"
  if [ -z "$pass" ]; then
    read -r -s -p "New password (min 8 chars): " pass
    echo ""
    read -r -s -p "Confirm: " pass2
    echo ""
    [ "$pass" = "$pass2" ] || fail "两次输入不一致"
  fi
  [ ${#pass} -ge 8 ] || fail "密码至少 8 位"

  local script_local="$REPO_ROOT/novaic-gateway/scripts/admin_reset_user_password.py"
  [ -f "$script_local" ] || fail "本地缺少 $script_local"
  info "同步 admin_reset_user_password.py → $API_HOST ..."
  rsync -avz -e ssh "$script_local" "$API_HOST:$SERVICES_DIR/novaic-gateway/scripts/" || fail "rsync 脚本失败"

  local db="/opt/novaic/data/gateway.db"
  info "SSH → $API_HOST : 重置 $email 的密码并撤销其 refresh token..."
  printf '%s' "$pass" | $API_SSH \
    "cd $SERVICES_DIR/novaic-gateway && test -x .venv/bin/python || { echo 'missing .venv'; exit 1; } && \
     .venv/bin/python scripts/admin_reset_user_password.py --db $db --revoke-refresh $(printf '%q' "$email") -" \
    || fail "远程执行失败（检查邮箱是否存在、.venv、gateway.db 路径）"
  ok "密码已更新；该用户需重新登录"
}

check_logs() {
  local svc="${2:-gateway}"
  info "查看 $svc 最新日志"
  case "$svc" in
    gateway)      $API_SSH "tail -50 /opt/novaic/data/logs/gateway-\$(date +%Y%m%d).log" ;;
    business)     $API_SSH "tail -50 /opt/novaic/data/logs/business-\$(date +%Y%m%d).log" ;;
    device)       $API_SSH "tail -50 /opt/novaic/data/logs/device-\$(date +%Y%m%d).log" ;;
    entangled)    $API_SSH "tail -50 /opt/novaic/data/logs/entangled.log" ;;
    cortex)       $API_SSH "tail -50 /opt/novaic/data/logs/cortex.log" ;;
    runtime)      $API_SSH "tail -50 /opt/novaic/data/logs/queue-service.log" ;;
    worker)       $API_SSH "tail -50 /opt/novaic/data/logs/task-worker-control-1.log" ;;
    health)       $API_SSH "tail -50 /opt/novaic/data/logs/health.log" ;;
    scheduler)    $API_SSH "tail -50 /opt/novaic/data/logs/scheduler.log" ;;
    relay)        $RELAY_SSH "journalctl -u novaic-quic-service --no-pager -n 50" ;;
    *)            fail "未知服务: $svc (可选: gateway, business, device, entangled, cortex, runtime, worker, health, scheduler, relay)" ;;
  esac
}

# ── 主入口 ────────────────────────────────────────────────────────────────────

show_help() {
  echo ""
  echo -e "${CYAN}NovAIC 部署工具${NC}"
  echo ""
  echo "用法: ./deploy <target> [option]"
  echo ""
  echo -e "${CYAN}客户端:${NC}"
  echo "  frontend [ver]    部署前端 OTA (默认 v0.3.0)"
  echo "  ios               构建并安装 iOS IPA"
  echo "  desktop           构建 macOS 桌面应用"
  echo ""
  echo -e "${CYAN}后端服务 (api.gradievo.com):${NC}"
  echo "  gateway           部署 Gateway + Business + Device + Entangled"
  echo "  business          部署 Business Service"
  echo "  device            部署 Device Service"
  echo "  runtime           部署 Agent Runtime (workers)"
  echo "  cortex            部署 Cortex (LLM 编排)"
  echo "  blob-service      部署 Blob Service"
  echo "  entangled         部署 Entangled (实体同步)"
  echo "  services          部署全部后端"
  echo ""
  echo -e "${CYAN}基础设施:${NC}"
  echo "  relay             部署 QUIC/Relay 到 relay 服务器"
  echo "  factory           部署 LLM Factory 到 newapi.gradievo.com"
  echo ""
  echo -e "${CYAN}聚合 & 运维:${NC}"
  echo "  all [ver]         部署全部"
  echo "  status            检查所有服务状态"
  echo "  logs [svc]        查看日志 (gateway|business|device|entangled|cortex|runtime|worker|health|scheduler|relay)"
  echo "  reset-password <email>  在 api 机上重置该用户登录密码（交互输入；可选 NOVAIC_DEPLOY_NEW_PASSWORD）"
  echo ""
}

case "${1}" in
  frontend)       deploy_frontend "$2" ;;
  gateway)        deploy_gateway ;;
  business)       deploy_shared_venv_service "novaic-business" ;;
  device)         deploy_shared_venv_service "novaic-device" ;;
  runtime)        deploy_single_service "novaic-agent-runtime" ;;
  blob-service)   deploy_single_service "novaic-blob-service" ;;
  cortex)         deploy_single_service "novaic-cortex" ;;
  entangled)      rsync_service "novaic-common"; rsync_service "Entangled"; sync_start_sh; restart_all; ok "Entangled 已部署" ;;
  services)       deploy_services ;;
  relay)          deploy_relay ;;
  factory)        deploy_factory ;;
  ios)            deploy_ios ;;
  desktop)        deploy_desktop ;;
  all)            deploy_all "$2" ;;
  status)         check_status ;;
  logs)           check_logs "$@" ;;
  reset-password) reset_user_password "$@" ;;
  *)              show_help ;;
esac
