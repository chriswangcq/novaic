}

# ── 状态检查 ──────────────────────────────────────────────────────────────────

check_status() {
  info "检查 api.gradievo.com 服务状态"
  echo ""
  info "LLM Factory Docker"
  $API_SSH "
    if [ -d '$FACTORY_DOCKER_DIR' ] && [ -f '$FACTORY_COMPOSE_FILE' ]; then
      cd '$FACTORY_DOCKER_DIR'
      docker compose --env-file '$(factory_env_file_for_namespace prod)' -f '$FACTORY_COMPOSE_FILE' ps llm-factory
      curl -sf http://127.0.0.1:19990/health >/dev/null && echo '  LLM Factory: healthy on 127.0.0.1:19990' || echo '  LLM Factory: health check failed'
    else
      echo '  Factory compose package 尚未安装: $FACTORY_DOCKER_DIR'
    fi
  "
  echo ""
  info "Host infra Docker Compose"
  $API_SSH "
    if [ -d '$HOST_INFRA_COMPOSE_DIR' ] && [ -f '$HOST_INFRA_COMPOSE_DIR/compose.yaml' ]; then
      cd '$HOST_INFRA_COMPOSE_DIR'
      if [ -f '$HOST_INFRA_ENV_FILE' ]; then
        docker compose --env-file '$HOST_INFRA_ENV_FILE' -f compose.yaml ps
      else
        echo '  WARN: $HOST_INFRA_ENV_FILE 不存在，使用 compose 默认值显示状态'
        docker compose -f compose.yaml ps
      fi
    else
      echo '  Host infra compose package 尚未安装: $HOST_INFRA_COMPOSE_DIR'
    fi
  "
  echo ""
  info "API backend Docker Compose"
  $API_SSH "
    if [ -d '$API_BACKEND_COMPOSE_DIR' ] && [ -f '$API_BACKEND_COMPOSE_DIR/compose.yaml' ]; then
      cd '$API_BACKEND_COMPOSE_DIR'
      if [ -f '$API_BACKEND_ENV_FILE' ]; then
        docker compose --env-file '$API_BACKEND_ENV_FILE' -f compose.yaml ps
      else
        echo '  WARN: $API_BACKEND_ENV_FILE 不存在，使用 compose 默认值显示状态'
        docker compose -f compose.yaml ps
      fi
    else
      echo '  Compose package 尚未安装: $API_BACKEND_COMPOSE_DIR'
    fi
  "
  echo ""
  info "Legacy/live port audit"
  $API_SSH '
    echo "  PORT  | PID    | SERVICE"
    echo "  ------|--------|--------"
    for port in 19900 19999 19998 19993 19997 19995 19994 19996; do
      pid=$(ss -tlnp 2>/dev/null | grep ":$port " | grep -oP "pid=\K\d+" | head -1)
      case $port in
        19900) svc="entangled" ;;
        19999) svc="gateway" ;;
        19998) svc="business" ;;
        19993) svc="device" ;;
        19997) svc="queue-svc" ;;
        19995) svc="blob-service" ;;
        19994) svc="sandboxd" ;;
        19996) svc="cortex" ;;
      esac
      if [ -n "$pid" ]; then
        printf "  %-6s| %-7s| ✓ %s\n" "$port" "$pid" "$svc"
      else
        printf "  %-6s| %-7s| ✗ %s (DOWN)\n" "$port" "-" "$svc"
      fi
    done
    echo ""
    echo "  ROLE                    EXPECTED ACTUAL STATUS"
    echo "  ----------------------- -------- ------ ------"
    check_role() {
      label="$1"
      pattern="$2"
      expected="$3"
      actual=$(pgrep -fc "$pattern" 2>/dev/null || true)
      actual=${actual:-0}
      if [ "$actual" -eq "$expected" ]; then
        printf "  %-23s %-8s %-6s ✓\n" "$label" "$expected" "$actual"
      else
        printf "  %-23s %-8s %-6s ✗\n" "$label" "$expected" "$actual"
      fi
    }
    if [ -x /opt/novaic/services/novaic-agent-runtime/.venv/bin/python ] && \
       [ -f /opt/novaic/services/novaic-agent-runtime/scripts/runtime_worker_roster.py ]; then
      /opt/novaic/services/novaic-agent-runtime/.venv/bin/python \
        /opt/novaic/services/novaic-agent-runtime/scripts/runtime_worker_roster.py \
        process-checks |
      while IFS="$(printf "\t")" read -r label pattern expected; do
        check_role "$label" "$pattern" "$expected"
      done
    else
      echo "  legacy runtime roster unavailable (expected after full cleanup)"
    fi
  '
  echo ""
  info "检查 relay 服务状态"
  $RELAY_SSH 'systemctl is-active novaic-quic-service && echo "  Relay: ✓ running" || echo "  Relay: ✗ stopped"'
}

compose_log_service() {
  case "$1" in
    entangled|gateway|business|device|cortex|subscriber) echo "$1" ;;
    runtime|queue|queue-service) echo "queue-service" ;;
    blob|blob-service) echo "blob-service" ;;
    sandboxd|sandbox) echo "sandboxd" ;;
    health) echo "runtime-health" ;;
    scheduler) echo "runtime-scheduler" ;;
    worker) echo "task-worker-control-1" ;;
    task-worker-control) echo "task-worker-control-1" ;;
    task-worker-execution) echo "task-worker-execution-1" ;;
    saga-worker) echo "saga-worker-1" ;;
    session-outbox) echo "session-outbox-worker" ;;
    saga-outbox) echo "saga-outbox-worker" ;;
    *) echo "" ;;
  esac
}

check_logs() {
  local svc="${2:-gateway}"
  info "查看 $svc 最新日志"
  if [ "$svc" = "factory" ] || [ "$svc" = "llm-factory" ]; then
    $API_SSH "cd '$FACTORY_DOCKER_DIR' && docker compose --env-file '$(factory_env_file_for_namespace prod)' -f '$FACTORY_COMPOSE_FILE' logs --tail 80 llm-factory"
    return
  fi
  case "$svc" in
    redis|coturn|quic|quic-relay|host-infra)
      local infra_svc="$svc"
      [ "$infra_svc" = "quic" ] && infra_svc="quic-relay"
      if [ "$infra_svc" = "host-infra" ]; then
        $API_SSH "cd '$HOST_INFRA_COMPOSE_DIR' && docker compose --env-file '$HOST_INFRA_ENV_FILE' -f compose.yaml logs --tail 80"
      else
        $API_SSH "cd '$HOST_INFRA_COMPOSE_DIR' && docker compose --env-file '$HOST_INFRA_ENV_FILE' -f compose.yaml logs --tail 80 '$infra_svc'"
      fi
      return
      ;;
  esac
  local compose_svc
  compose_svc="$(compose_log_service "$svc")"
  if [ -n "$compose_svc" ]; then
    if $API_SSH "test -d '$API_BACKEND_COMPOSE_DIR' && test -f '$API_BACKEND_COMPOSE_DIR/compose.yaml'"; then
      $API_SSH "
        cd '$API_BACKEND_COMPOSE_DIR'
        if [ -f '$API_BACKEND_ENV_FILE' ]; then
          docker compose --env-file '$API_BACKEND_ENV_FILE' -f compose.yaml logs --tail 80 '$compose_svc'
        else
          docker compose -f compose.yaml logs --tail 80 '$compose_svc'
        fi
      "
      return
    fi
  fi
  case "$svc" in
    gateway)      $API_SSH "tail -50 /opt/novaic/data/logs/gateway-\$(date +%Y%m%d).log" ;;
    business)     $API_SSH "tail -50 /opt/novaic/data/logs/business-\$(date +%Y%m%d).log" ;;
    device)       $API_SSH "tail -50 /opt/novaic/data/logs/device-\$(date +%Y%m%d).log" ;;
    entangled)    $API_SSH "tail -50 /opt/novaic/data/logs/entangled.log" ;;
    sandboxd)     $API_SSH "tail -50 /opt/novaic/data/logs/sandboxd.log" ;;
    cortex)       $API_SSH "tail -50 /opt/novaic/data/logs/cortex.log" ;;
    runtime)      $API_SSH "tail -50 /opt/novaic/data/logs/queue-service.log" ;;
    worker)       $API_SSH "tail -50 /opt/novaic/data/logs/task-worker-control-1.log" ;;
    health)       $API_SSH "tail -50 /opt/novaic/data/logs/health.log" ;;
    scheduler)    $API_SSH "tail -50 /opt/novaic/data/logs/scheduler.log" ;;
    relay)        $RELAY_SSH "journalctl -u novaic-quic-service --no-pager -n 50" ;;
    *)            fail "未知服务: $svc (可选: gateway, business, device, entangled, sandboxd, cortex, runtime, worker, health, scheduler, factory, redis, coturn, quic, host-infra, relay)" ;;
  esac
}

