  info "拉取 Release Controller image (image=$image_ref)..."
  compose_release_controller_env "$RELEASE_CONTROLLER_ENV_FILE" "pull release_controller" \
    || fail "Release Controller image pull 失败"
  info "启动 Release Controller image release..."
  compose_release_controller_env "$RELEASE_CONTROLLER_ENV_FILE" "up -d --no-build release_controller" \
    || fail "Release Controller image up 失败"
  compose_release_controller_env "$RELEASE_CONTROLLER_ENV_FILE" "ps release_controller" \
    || fail "Release Controller image ps 失败"
  wait_for_remote_http "http://127.0.0.1:$port/health" "Release Controller image release"
  ok "Release Controller image release 已部署 (image=$image_ref)"
}

