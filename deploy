test -d '$HOST_INFRA_RUNTIME_DIR/redis'
backup_dir=\"/opt/novaic/backups/host-infra-cleanup-\$(date +%Y%m%d-%H%M%S)\"
mkdir -p \"\$backup_dir\"
chmod 700 \"\$backup_dir\"
for path in \
  /opt/novaic/start.sh \
  /etc/systemd/system/novaic-quic-service.service \
  /etc/turnserver.conf \
  /etc/redis/redis.conf; do
  if [ -e \"\$path\" ]; then
    cp -a \"\$path\" \"\$backup_dir/\$(basename \"\$path\")\"
  fi
done
if [ -d /opt/novaic/novaic-quic-service ]; then
  find /opt/novaic/novaic-quic-service -maxdepth 2 -type f | head -200 > \"\$backup_dir/old-quic-files.txt\" || true
fi
systemctl stop redis-server coturn novaic-quic-service 2>/dev/null || true
systemctl disable redis-server coturn novaic-quic-service 2>/dev/null || true
if command -v apt-get >/dev/null 2>&1; then
  DEBIAN_FRONTEND=noninteractive apt-get purge -y redis-server coturn > \"\$backup_dir/apt-purge.log\" 2>&1 || true
fi
