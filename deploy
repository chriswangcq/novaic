assert_docker_listener() {
  proto=\"\$1\"
  port=\"\$2\"
  if [ \"\$proto\" = tcp ]; then
    line=\$(ss -tlnp 2>/dev/null | grep \":\$port \" | head -1 || true)
  else
    line=\$(ss -ulnp 2>/dev/null | grep \":\$port \" | head -1 || true)
  fi
  [ -n \"\$line\" ] || { echo \"missing \$proto listener on \$port\" >&2; exit 1; }
  pid=\$(printf \"%s\" \"\$line\" | grep -oP 'pid=\\K[0-9]+' | head -1 || true)
  [ -n \"\$pid\" ] || { echo \"missing pid for \$proto listener on \$port\" >&2; exit 1; }
  cgroup=\$(cat \"/proc/\$pid/cgroup\" 2>/dev/null || true)
  printf \"%s/%s pid=%s cgroup=%s\\n\" \"\$proto\" \"\$port\" \"\$pid\" \"\$cgroup\"
  printf \"%s\" \"\$cgroup\" | grep -Eq 'docker|containerd' || {
    echo \"listener \$proto/\$port is not Docker-owned\" >&2
    exit 1
  }
}

assert_docker_listener tcp 6379
assert_docker_listener udp 3478
assert_docker_listener tcp 3478
assert_docker_listener udp 443

for unit in redis-server coturn novaic-quic-service; do
  if systemctl is-active --quiet \"\$unit\" 2>/dev/null; then
    echo \"host unit still active: \$unit\" >&2
    exit 1
  fi
done
systemctl is-active --quiet nginx
curl -fsS http://127.0.0.1:19996/ready >/dev/null
curl -fsS http://127.0.0.1:19991/ready >/dev/null" \
    || fail "Host infra 验证失败"
  ok "Host infra Docker ownership 验证通过"
}

cleanup_host_bare_infra_residue() {
