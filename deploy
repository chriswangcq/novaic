#!/bin/bash
# NovAIC 统一部署入口
# 用法: ./deploy <target> [options]
#
# 代码同步: 本地 rsync → 服务器
# 后端主路径: API 机器 Docker Compose
# 旧 host venv/start.sh 路径仅保留为 services-legacy 回滚入口

set -e

# ── 配置 ──────────────────────────────────────────────────────────────────────
REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
RELAY_HOST="47.243.221.45"
RELAY_PORT="22"
RELAY_SSH="ssh -p $RELAY_PORT root@$RELAY_HOST"
API_HOST="root@api.gradievo.com"
API_SSH="ssh $API_HOST"
VERSION="${2:-0.3.0}"
SERVICES_DIR="/opt/novaic/services"
API_BACKEND_BUILD_DIR="/opt/novaic/docker-builds/api-backend"
API_BACKEND_COMPOSE_DIR="/opt/novaic/docker/api-backend"
API_BACKEND_ENV_FILE="/opt/novaic/docker/api-backend.env"
API_BACKEND_IMAGE="${NOVAIC_API_BACKEND_IMAGE:-novaic/api-backend:local}"
HOST_INFRA_COMPOSE_DIR="/opt/novaic/docker/host-infra"
HOST_INFRA_ENV_FILE="/opt/novaic/docker/host-infra.env"
HOST_INFRA_BUILD_DIR="/opt/novaic/docker-builds/host-infra"
HOST_INFRA_RUNTIME_DIR="/opt/novaic/host-infra"
QUIC_IMAGE="${NOVAIC_QUIC_IMAGE:-novaic/quic-service:local}"
FACTORY_DOCKER_DIR="/opt/novaic/llm-factory"
FACTORY_APP_DIR="$FACTORY_DOCKER_DIR/app"
FACTORY_COMPOSE_FILE="$FACTORY_DOCKER_DIR/docker-compose.yml"
RELEASE_CONTROLLER_DOCKER_DIR="/opt/novaic/docker/release-controller"
RELEASE_CONTROLLER_RUNTIME_DIR="/opt/novaic/release-controller"
RELEASE_CONTROLLER_COMPOSE_FILE="$RELEASE_CONTROLLER_DOCKER_DIR/compose.yaml"
RELEASE_CONTROLLER_ENV_FILE="$RELEASE_CONTROLLER_DOCKER_DIR/compose.env"
RELEASE_CONTROLLER_IMAGE="${NOVAIC_RELEASE_CONTROLLER_IMAGE:-novaic/release-controller:local}"
RSYNC_EXCLUDE="--exclude .git --exclude __pycache__ --exclude .pytest_cache --exclude .mypy_cache --exclude '*.pyc' --exclude target --exclude build --exclude dist --exclude artifacts --exclude .venv --exclude node_modules --exclude '*.db'"
TAR_EXCLUDE_ARGS=(
  --exclude=.git
  --exclude=__pycache__
  --exclude=.pytest_cache
  --exclude=.mypy_cache
  --exclude='*.pyc'
  --exclude=target
  --exclude=build
  --exclude=dist
  --exclude=artifacts
  --exclude=.venv
  --exclude=node_modules
  --exclude='*.db'
)
API_BACKEND_CONTEXT_DIRS=(
  docker
  Entangled
  novaic-agent-runtime
  novaic-blob-service
  novaic-business
  novaic-common
  novaic-cortex
  novaic-device
  novaic-gateway
  novaic-logicalfs
  novaic-sandbox-sdk
  novaic-sandbox-service
)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}▸ $1${NC}"; }
ok()    { echo -e "${GREEN}✓ $1${NC}"; }
warn()  { echo -e "${YELLOW}⚠ $1${NC}"; }
fail()  { echo -e "${RED}✗ $1${NC}"; exit 1; }

have_rsync() {
  command -v rsync >/dev/null 2>&1
}

tar_no_xattrs_flag() {
  if tar --help 2>/dev/null | grep -q -- '--no-xattrs'; then
    echo "--no-xattrs"
  else
    echo ""
  fi
}

copy_file_to_api() {
  local src="$1"
  local dest="$2"
  local dest_dir
  dest_dir="$(dirname "$dest")"
  [ -f "$src" ] || fail "本地文件不存在: $src"
  $API_SSH "mkdir -p '$dest_dir'" || fail "创建远端目录失败: $dest_dir"
  if have_rsync; then
    rsync -avz -e ssh "$src" "$API_HOST:$dest" || fail "同步文件失败: $src -> $dest"
  else
    ssh "$API_HOST" "cat > '$dest'" < "$src" || fail "同步文件失败: $src -> $dest"
  fi
}

sync_dir_to_api() {
  local src="$1"
  local dest="$2"
  [ -d "$src" ] || fail "本地目录不存在: $src"
  if have_rsync; then
    rsync -avzL --delete $RSYNC_EXCLUDE -e ssh "$src/" "$API_HOST:$dest/" \
      || fail "同步目录失败: $src -> $dest"
  else
    local tar_flag
    tar_flag="$(tar_no_xattrs_flag)"
    $API_SSH "rm -rf '$dest' && mkdir -p '$dest'" || fail "准备远端目录失败: $dest"
    # shellcheck disable=SC2086
    tar $tar_flag "${TAR_EXCLUDE_ARGS[@]}" -cf - -C "$src" . \
      | $API_SSH "tar -xf - -C '$dest'" \
      || fail "同步目录失败: $src -> $dest"
  fi
}

validate_namespace() {
  local namespace="$1"
  case "$namespace" in
    prod|staging|preview-pr-[0-9]*) return 0 ;;
    *) fail "非法 namespace: $namespace (允许: prod, staging, preview-pr-<id>)" ;;
  esac
}

namespace_port_base() {
  case "$1" in
    prod) echo "19900" ;;
    staging) echo "29900" ;;
    preview-pr-*) echo "39000" ;;
    *) fail "无法为 namespace 计算端口基准: $1" ;;
  esac
}

namespace_redis_url() {
  case "$1" in
    prod) echo "redis://127.0.0.1:6379/0" ;;
    staging) echo "redis://127.0.0.1:6379/1" ;;
    preview-pr-*) echo "redis://127.0.0.1:6379/2" ;;
    *) fail "无法为 namespace 计算 Redis URL: $1" ;;
  esac
}

api_backend_env_file_for_namespace() {
  echo "/opt/novaic/docker/api-backend.$1.env"
}

api_backend_etc_dir_for_namespace() {
  echo "/opt/novaic/etc/$1"
}

api_backend_data_dir_for_namespace() {
  echo "/opt/novaic/data/$1"
}

api_backend_postgres_secrets_dir_for_namespace() {
  echo "/opt/novaic/postgres/secrets/$1"
}

factory_env_file_for_namespace() {
  echo "$FACTORY_DOCKER_DIR/$1/compose.env"
}

factory_runtime_env_file_for_namespace() {
  echo "$FACTORY_DOCKER_DIR/$1/runtime.env"
}

factory_data_dir_for_namespace() {
  echo "$FACTORY_DOCKER_DIR/$1/data"
}

factory_secrets_dir_for_namespace() {
  echo "$FACTORY_DOCKER_DIR/$1/secrets"
}

factory_port_for_namespace() {
  case "$1" in
    prod) echo "19990" ;;
    staging) echo "29990" ;;
    preview-pr-*) echo "39990" ;;
    *) fail "无法为 namespace 计算 Factory 端口: $1" ;;
  esac
}

factory_postgres_network_for_namespace() {
  case "$1" in
    prod) echo "novaic-postgres_default" ;;
    staging) echo "novaic-staging-postgres" ;;
    preview-pr-*) echo "novaic-preview-postgres" ;;
    *) fail "无法为 namespace 计算 Factory Postgres network: $1" ;;
  esac
}

normalize_image_ref() {
  local kind="$1"
  local ref="$2"
  local base
  case "$kind" in
    api-backend) base="novaic/api-backend" ;;
    llm-factory) base="novaic/llm-factory" ;;
    release-controller) base="novaic/release-controller" ;;
    *) fail "未知镜像类型: $kind" ;;
  esac
  if [[ "$ref" =~ ^sha256:[0-9a-fA-F]{64}$ ]]; then
    echo "$base@$ref"
  elif [[ "$ref" =~ ^sha-?[0-9a-fA-F]{6,40}$ || "$ref" =~ ^[0-9a-fA-F]{6,40}$ ]]; then
    echo "$base:$ref"
  else
    echo "$ref"
  fi
}

image_ref_tag() {
  local ref="$1"
  local last="${ref##*/}"
  [[ "$last" == *:* ]] || return 1
  echo "${last##*:}"
}

image_digest_from_ref() {
  local ref="$1"
  if [[ "$ref" =~ @sha256:([0-9a-fA-F]{64})$ ]]; then
    echo "sha256:${BASH_REMATCH[1]}"
  else
    echo ""
  fi
}

release_id_from_image_ref() {
  local ref="$1"
  local digest tag
  digest="$(image_digest_from_ref "$ref")"
  if [ -n "$digest" ]; then
    echo "sha256-${digest:7:12}"
    return
  fi
  tag="$(image_ref_tag "$ref")" || fail "镜像引用缺少 tag 或 digest: $ref"
  echo "$tag"
}

validate_immutable_image_ref() {
  local namespace="$1"
  local ref="$2"
  local tag
  if [[ "$ref" =~ @sha256:[0-9a-fA-F]{64}$ ]]; then
    return 0
  fi
  tag="$(image_ref_tag "$ref")" || fail "$namespace image 必须带 digest 或 sha tag: $ref"
  case "$tag" in
    latest|local|dev|main|master|prod|staging)
      fail "$namespace image 禁止使用可变 tag: $ref"
      ;;
  esac
  if [[ "$tag" =~ ^sha-?[0-9a-fA-F]{6,40}$ || "$tag" =~ ^[0-9a-fA-F]{6,40}$ ]]; then
    return 0
  fi
  fail "$namespace image 只允许 digest 或 sha tag: $ref"
}

# ── 通用：同步代码到服务器（不重启） ──────────────────────────────────────────
rsync_service() {
  local name="$1"
  local local_dir="$REPO_ROOT/$name"
  [ -d "$local_dir" ] || fail "本地目录不存在: $local_dir"
  info "同步 $name..."
  # Clean stale generated artifacts first. These are excluded from rsync, so
  # --delete cannot remove old build outputs by itself.
  $API_SSH "find $SERVICES_DIR/$name -type d \( -name __pycache__ -o -name .pytest_cache -o -name .mypy_cache -o -name build -o -name dist -o -name artifacts \) -exec rm -rf {} + 2>/dev/null" || true
  rsync -avzL --delete $RSYNC_EXCLUDE -e ssh "$local_dir/" "$API_HOST:$SERVICES_DIR/$name/" || fail "rsync $name 失败"
}

install_service_requirements() {
  local name="$1"
  [ -f "$REPO_ROOT/$name/requirements.txt" ] || return 0
  info "安装 $name 依赖..."
  $API_SSH "set -e; cd $SERVICES_DIR/$name; \
    rm -rf .venv; \
    python3 -m venv .venv; \
    .venv/bin/python -m pip install -q -r requirements.txt" \
    || fail "$name pip install 失败"
}

remove_retired_backend_package() {
  local name="$1"
  info "清理退役后端包 $name..."
  $API_SSH "rm -rf '$SERVICES_DIR/$name'" || fail "清理 $name 失败"
}

sync_backend_infra_bootstrap() {
  # start.sh always restarts sandboxd and Cortex, so every backend restart path
  # must deploy their explicit substrate packages before process launch.
  remove_retired_backend_package "novaic-sandbox-core"
  rsync_service "novaic-sandbox-sdk"
  rsync_service "novaic-logicalfs"
  rsync_service "novaic-sandbox-service"
  install_service_requirements "novaic-sandbox-service"
}

# ── 客户端部署 ────────────────────────────────────────────────────────────────

deploy_frontend() {
  local ver="${1:-$VERSION}"
  info "部署前端 OTA (v${ver})"
  cd "$REPO_ROOT/novaic-app"
  info "构建前端..."
  VITE_BASE="/resource/frontend/v${ver}/" npm run build || fail "前端构建失败"
  info "上传到 relay..."
  $RELAY_SSH "mkdir -p /opt/novaic/static/v${ver}"
  rsync -avz --delete -e "ssh -p $RELAY_PORT" dist/ root@$RELAY_HOST:/opt/novaic/static/v${ver}/ || fail "rsync 失败"
  ok "前端 v${ver} 已部署到 https://relay.gradievo.com/resource/frontend/v${ver}/"
}

deploy_ios() {
  info "构建 iOS IPA 并安装"
  cd "$REPO_ROOT/novaic-app"
  # Fix: Xcode 26.x beta ships MacOSX26.2.sdk, causing aws-lc-sys (cc-rs) to
  # use -mmacosx-version-min=26.2 for host code, which fails compilation.
  # Force a sane deployment target for the host (macOS) build.
  export MACOSX_DEPLOYMENT_TARGET="15.0"
  npm run tauri ios build -- --export-method debugging || fail "iOS 构建失败"
  local IPA="src-tauri/gen/apple/build/arm64/ByClaw.ipa"
  [ -f "$IPA" ] || fail "IPA 不存在: $IPA"
  local DEVICE=$(xcrun devicectl list devices 2>/dev/null | awk '/connected/ && !/Simulator/ {for(i=1;i<=NF;i++) if($i~/^[0-9A-F]{8}-/) {print $i;break}}' | head -1)
  if [ -z "$DEVICE" ]; then warn "未找到设备，IPA 在: $IPA"
  else xcrun devicectl device install app --device "$DEVICE" "$IPA" && ok "iOS 已安装" || fail "安装失败"; fi
}

deploy_desktop() {
  info "构建 macOS 桌面应用"
  cd "$REPO_ROOT/novaic-app"
  npm run tauri:build -- --bundles app || fail "桌面构建失败"
  info "安装到 /Applications"
  rm -rf /Applications/ByClaw.app
  cp -R src-tauri/target/release/bundle/macos/ByClaw.app /Applications/
  ok "桌面应用已部署到 /Applications/ByClaw.app"
}

# ── 通用：同步 start.sh + 重启 ────────────────────────────────────────────────
sync_start_sh() {
  info "同步 start.sh..."
  scp -q "$REPO_ROOT/scripts/start.sh" "$API_HOST:/opt/novaic/start.sh"
}

remote_epoch() {
  $API_SSH 'date +%s'
}

fresh_smoke_default_epoch() {
  $API_SSH 'date -d "15 minutes ago" +%s'
}

verify_fresh_backend_logs() {
  local since_epoch="${1:-}"
  if [ -z "$since_epoch" ]; then
    since_epoch="$(fresh_smoke_default_epoch)" || fail "获取远端 fresh-smoke 默认时间失败"
  fi
  [[ "$since_epoch" =~ ^[0-9]+$ ]] || fail "fresh-smoke timestamp 必须是 epoch 秒: $since_epoch"

  info "检查后端 fresh-smoke 日志（since_epoch=${since_epoch}）..."
  $API_SSH "NOVAIC_DEPLOY_SMOKE_SINCE_EPOCH='$since_epoch' bash -s" <<'REMOTE_SMOKE'
set -euo pipefail

LOG_DIR="/opt/novaic/data/logs"
since="${NOVAIC_DEPLOY_SMOKE_SINCE_EPOCH:?}"
today="$(date +%Y%m%d)"

mapfile -t runtime_logs < <(
  /opt/novaic/services/novaic-agent-runtime/.venv/bin/python \
    /opt/novaic/services/novaic-agent-runtime/scripts/runtime_worker_roster.py \
    log-files
)

required_logs=(
  "entangled.log"
  "gateway-${today}.log"
  "business-${today}.log"
  "device-${today}.log"
  "queue-service.log"
  "blob-service.log"
  "sandboxd.log"
  "cortex.log"
  "${runtime_logs[@]}"
)

failures=0
echo "  Fresh log smoke since epoch: ${since}"
for name in "${required_logs[@]}"; do
  path="${LOG_DIR}/${name}"
  if [ ! -s "$path" ]; then
    printf "  %-34s ✗ missing-or-empty\n" "$name"
    failures=1
    continue
  fi
  mtime="$(stat -c %Y "$path")"
  if [ "$mtime" -lt "$since" ]; then
    printf "  %-34s ✗ stale (mtime=%s)\n" "$name" "$mtime"
    failures=1
    continue
  fi
  printf "  %-34s ✓ fresh (mtime=%s)\n" "$name" "$mtime"
done

exit "$failures"
REMOTE_SMOKE
  ok "后端 fresh-smoke 日志检查通过"
}

restart_all() {
  info "重启全部后端服务（通过 start.sh）..."
  local smoke_since
  smoke_since="$(remote_epoch)" || fail "获取远端重启边界时间失败"
  $API_SSH 'bash /opt/novaic/start.sh --stop && bash /opt/novaic/start.sh' || fail "重启失败"
  verify_fresh_backend_logs "$smoke_since"
}

# ── 后端服务部署（Docker Compose 主路径） ────────────────────────────────────

sync_api_backend_compose() {
  info "同步 API backend Compose package..."
  sync_dir_to_api "$REPO_ROOT/docker/api-backend" "$API_BACKEND_COMPOSE_DIR"
}

sync_api_backend_config_snapshot() {
  info "同步 API backend env 生成所需配置快照..."
  copy_file_to_api "$REPO_ROOT/novaic-common/config/services.json" "$API_BACKEND_COMPOSE_DIR/services.json"
}

sync_api_backend_build_context() {
  info "同步 API backend Docker build context..."
  $API_SSH "rm -rf '$API_BACKEND_BUILD_DIR' && mkdir -p '$API_BACKEND_BUILD_DIR'" \
    || fail "准备 Docker build context 失败"
  rsync -avz -e ssh "$REPO_ROOT/.dockerignore" "$API_HOST:$API_BACKEND_BUILD_DIR/.dockerignore" \
    || fail "同步 .dockerignore 失败"
  for path in "${API_BACKEND_CONTEXT_DIRS[@]}"; do
    [ -e "$REPO_ROOT/$path" ] || fail "本地路径不存在: $path"
    rsync -avzL --delete $RSYNC_EXCLUDE -e ssh \
      "$REPO_ROOT/$path/" \
      "$API_HOST:$API_BACKEND_BUILD_DIR/$path/" \
      || fail "同步 build context/$path 失败"
  done
}

write_api_backend_env() {
  local namespace="${1:-prod}"
  local image_ref="${2:-$API_BACKEND_IMAGE}"
  local env_file="${3:-$API_BACKEND_ENV_FILE}"
  local services_json="${4:-$API_BACKEND_BUILD_DIR/novaic-common/config/services.json}"
  validate_namespace "$namespace"
  local release_id image_digest port_base redis_url etc_dir data_dir postgres_secrets_dir compose_project
  release_id="$(release_id_from_image_ref "$image_ref")"
  image_digest="$(image_digest_from_ref "$image_ref")"
  port_base="$(namespace_port_base "$namespace")"
  redis_url="$(namespace_redis_url "$namespace")"
  etc_dir="$(api_backend_etc_dir_for_namespace "$namespace")"
  data_dir="$(api_backend_data_dir_for_namespace "$namespace")"
  postgres_secrets_dir="$(api_backend_postgres_secrets_dir_for_namespace "$namespace")"
  compose_project="novaic-$namespace"
  info "生成 API backend Compose env 文件 (namespace=$namespace, image=$image_ref)..."
  $API_SSH "python3 '$API_BACKEND_COMPOSE_DIR/write_env.py' \
    --services-json '$services_json' \
    --runtime-switches '$etc_dir/runtime_switches.json' \
    --secrets-json '$etc_dir/secrets.json' \
    --output '$env_file' \
    --image '$image_ref' \
    --namespace '$namespace' \
    --release-id '$release_id' \
    --environment '$namespace' \
    --host-id 'api-host-1' \
    --compose-project '$compose_project' \
    --image-digest '$image_digest' \
    --data-dir '$data_dir' \
    --postgres-secrets-dir '$postgres_secrets_dir' \
    --etc-dir '$etc_dir' \
    --redis-url '$redis_url' \
    --registry-table 'service_registry_instances' \
    --port-base '$port_base'" \
    || fail "生成 API backend env 失败"
}

compose_api_backend_env() {
  local env_file="$1"
  shift
  $API_SSH "cd '$API_BACKEND_COMPOSE_DIR' && docker compose \
    --env-file '$env_file' \
    -f compose.yaml $*"
}

compose_api_backend() {
  compose_api_backend_env "$API_BACKEND_ENV_FILE" "$@"
}

build_api_backend_image() {
  info "构建 API backend Docker image ($API_BACKEND_IMAGE)..."
  $API_SSH "cd '$API_BACKEND_BUILD_DIR' && docker build \
    -f docker/api-backend/Dockerfile \
    -t '$API_BACKEND_IMAGE' ." \
    || fail "API backend Docker image 构建失败"
}

validate_api_backend_compose() {
  local env_file="${1:-$API_BACKEND_ENV_FILE}"
  local namespace="${2:-prod}"
  info "验证 API backend Compose config (namespace=$namespace)..."
  compose_api_backend_env "$env_file" "config > '$API_BACKEND_COMPOSE_DIR/compose.$namespace.rendered.yaml'" \
    || fail "docker compose config 失败"
  compose_api_backend_env "$env_file" "config --services > '$API_BACKEND_COMPOSE_DIR/compose.$namespace.services.txt'" \
    || fail "docker compose config --services 失败"
}

stop_legacy_host_backends() {
  info "停止 legacy host-process 后端（start.sh rollback path）..."
  $API_SSH 'if [ -f /opt/novaic/start.sh ]; then bash /opt/novaic/start.sh --stop || true; fi' \
    || fail "停止 legacy host-process 后端失败"
}

stop_legacy_api_backend_compose_project() {
  info "停止旧单环境 API backend Compose project（novaic-api-backend）..."
  $API_SSH "set -euo pipefail
ids=\$(docker ps -aq --filter label=com.docker.compose.project=novaic-api-backend)
if [ -n \"\$ids\" ]; then
  docker rm -f \$ids
fi" || fail "停止旧 API backend Compose project 失败"
}

stop_legacy_factory_compose_project() {
  info "停止旧单环境 LLM Factory Compose/container（novaic-llm-factory）..."
  $API_SSH "set -euo pipefail
ids=\$(docker ps -aq --filter label=com.docker.compose.project=novaic-llm-factory)
name_ids=\$(docker ps -aq --filter name='^/novaic-llm-factory$')
all_ids=\"\$ids \$name_ids\"
if [ -n \"\$(printf '%s' \"\$all_ids\" | tr -d '[:space:]')\" ]; then
  docker rm -f \$all_ids || true
  for _ in \$(seq 1 30); do
    remaining=\$(docker ps -aq --filter label=com.docker.compose.project=novaic-llm-factory)
    remaining_names=\$(docker ps -aq --filter name='^/novaic-llm-factory$')
    if [ -z \"\$(printf '%s %s' \"\$remaining\" \"\$remaining_names\" | tr -d '[:space:]')\" ]; then
      exit 0
    fi
    sleep 1
  done
  echo 'legacy LLM Factory container removal did not settle' >&2
  exit 1
fi" || fail "停止旧 LLM Factory Compose/container 失败"
}

deploy_api_backend_compose() {
  local namespace="prod"
  warn "services/api-backend 是远端 build 回退路径；主 CD 路径请用 ./deploy services-image <namespace> <image-ref>"
  info "部署 API backend Docker Compose 到 api.gradievo.com (remote build fallback, namespace=$namespace)"
  sync_api_backend_compose
  sync_api_backend_build_context
  build_api_backend_image
  write_api_backend_env "$namespace" "$API_BACKEND_IMAGE" "$API_BACKEND_ENV_FILE" "$API_BACKEND_BUILD_DIR/novaic-common/config/services.json"
  validate_api_backend_compose "$API_BACKEND_ENV_FILE" "$namespace"
  stop_legacy_host_backends
  info "启动 API backend Compose topology..."
  compose_api_backend "up -d --remove-orphans" || fail "docker compose up 失败"
  compose_api_backend "ps" || fail "docker compose ps 失败"
  ok "API backend Docker Compose 已部署"
}

deploy_services_image() {
  local namespace="${1:-}"
  local raw_image_ref="${2:-}"
  [ -n "$namespace" ] || fail "用法: ./deploy services-image <namespace> <image-ref|sha|digest>"
  [ -n "$raw_image_ref" ] || fail "用法: ./deploy services-image <namespace> <image-ref|sha|digest>"
  validate_namespace "$namespace"
  local image_ref env_file
