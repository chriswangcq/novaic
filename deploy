#!/bin/bash
# NovAIC 统一部署入口
# 用法: ./deploy <target> [options]
#
# 代码同步: 本地 rsync → 服务器
# 进程管理: 服务器端 start.sh / restart_gw.sh（不在本地 nohup）

set -e

# ── 配置 ──────────────────────────────────────────────────────────────────────
REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
RELAY_HOST="47.243.221.45"
RELAY_PORT="22"
RELAY_SSH="ssh -p $RELAY_PORT root@$RELAY_HOST"
API_HOST="root@api.gradievo.com"
API_SSH="ssh $API_HOST"
VERSION="${2:-0.3.0}"
SERVICES_DIR="/opt/novaic/services"
RSYNC_EXCLUDE="--exclude .git --exclude __pycache__ --exclude '*.pyc' --exclude target --exclude .venv --exclude node_modules"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}▸ $1${NC}"; }
ok()    { echo -e "${GREEN}✓ $1${NC}"; }
warn()  { echo -e "${YELLOW}⚠ $1${NC}"; }
fail()  { echo -e "${RED}✗ $1${NC}"; exit 1; }

# ── 通用：同步代码到服务器（不重启） ──────────────────────────────────────────
rsync_service() {
  local name="$1"
  local local_dir="$REPO_ROOT/$name"
  [ -d "$local_dir" ] || fail "本地目录不存在: $local_dir"
  info "同步 $name..."
  rsync -avz $RSYNC_EXCLUDE -e ssh "$local_dir/" "$API_HOST:$SERVICES_DIR/$name/" || fail "rsync $name 失败"
}

# ── 客户端部署 ────────────────────────────────────────────────────────────────

deploy_frontend() {
  local ver="${1:-$VERSION}"
  info "部署前端 OTA (v${ver})"
  cd "$REPO_ROOT/novaic-app"
  info "构建前端..."
  VITE_BASE="/resource/frontend/v${ver}/" npm run build || fail "前端构建失败"
  info "上传到 relay..."
  $RELAY_SSH "mkdir -p /opt/novaic/static/v${ver}"
  rsync -avz --delete -e "ssh -p $RELAY_PORT" dist/ root@$RELAY_HOST:/opt/novaic/static/v${ver}/ || fail "rsync 失败"
  ok "前端 v${ver} 已部署到 https://relay.gradievo.com/resource/frontend/v${ver}/"
}

deploy_ios() {
  info "构建 iOS IPA 并安装"
  cd "$REPO_ROOT/novaic-app"
  npm run tauri ios build -- --export-method debugging || fail "iOS 构建失败"
  local IPA="src-tauri/gen/apple/build/arm64/NovAIC.ipa"
  [ -f "$IPA" ] || fail "IPA 不存在: $IPA"
  local DEVICE=$(xcrun devicectl list devices 2>/dev/null | awk '/connected/ && !/Simulator/ {for(i=1;i<=NF;i++) if($i~/^[0-9A-F]{8}-/) {print $i;break}}' | head -1)
  if [ -z "$DEVICE" ]; then warn "未找到设备，IPA 在: $IPA"
  else xcrun devicectl device install app --device "$DEVICE" "$IPA" && ok "iOS 已安装" || fail "安装失败"; fi
}

deploy_desktop() {
  info "构建 macOS 桌面应用"
  cd "$REPO_ROOT/novaic-app"
  npm run tauri:build -- --bundles app || fail "桌面构建失败"
  info "安装到 /Applications"
  rm -rf /Applications/NovAIC.app
  cp -R src-tauri/target/release/bundle/macos/NovAIC.app /Applications/
  ok "桌面应用已部署到 /Applications/NovAIC.app"
}

# ── 后端服务部署（rsync + 服务器端 start.sh 管理进程） ────────────────────────

deploy_gateway() {
  info "部署 Gateway"
  rsync_service "novaic-gateway"
  info "重启全部后端服务（通过 start.sh）..."
  $API_SSH 'bash /opt/novaic/start.sh --stop && bash /opt/novaic/start.sh' || fail "重启失败"
  ok "Gateway 已部署（全部服务已重启）"
}

deploy_single_service() {
  local name="$1"
  rsync_service "$name"
  info "重启全部后端服务（通过 start.sh）..."
  $API_SSH 'bash /opt/novaic/start.sh --stop && bash /opt/novaic/start.sh' || fail "重启失败"
  ok "$name 已部署（全部服务已重启）"
}

deploy_services() {
  info "部署全部后端服务到 api.gradievo.com"
  echo ""

  # 同步所有服务代码
  for svc in novaic-gateway novaic-agent-runtime novaic-runtime-orchestrator \
             novaic-tools-server novaic-storage-a novaic-storage-b; do
    rsync_service "$svc"
  done

  echo ""
  info "重启全部服务（start.sh）..."
  $API_SSH 'bash /opt/novaic/start.sh --stop' || true
  sleep 2
  $API_SSH 'bash /opt/novaic/start.sh' || fail "启动失败"

  echo ""
  ok "全部后端服务已部署！"
}

deploy_relay() {
  info "部署 novaic-quic-service 到 relay"
  cd "$REPO_ROOT/novaic-quic-service"
  info "同步代码到服务器..."
  rsync -avz -e "ssh -p $RELAY_PORT" --exclude target --exclude .git . root@$RELAY_HOST:/opt/novaic/novaic-quic-service/ || fail "rsync 失败"
  info "服务器拉取并编译..."
  $RELAY_SSH 'export PATH="$HOME/.cargo/bin:$PATH" && cd /opt/novaic/novaic-quic-service && cargo build --release && systemctl stop novaic-quic-service && cp target/release/novaic-quic-service ./ && systemctl start novaic-quic-service' || fail "编译或重启失败"
  $RELAY_SSH 'systemctl is-active novaic-quic-service' && ok "Relay 已部署" || warn "服务未运行"
}

# ── 聚合命令 ──────────────────────────────────────────────────────────────────

deploy_all() {
  deploy_frontend "$1"
  deploy_services
  deploy_relay
  deploy_ios
  deploy_desktop
  echo ""
  ok "🎉 全部部署完成！"
}

# ── 状态检查 ──────────────────────────────────────────────────────────────────

check_status() {
  info "检查 api.gradievo.com 服务状态"
  echo ""
  $API_SSH '
    echo "  PORT  | PID    | SERVICE"
    echo "  ------|--------|--------"
    for port in 19993 19994 19995 19998 19999; do
      pid=$(ss -tlnp 2>/dev/null | grep ":$port " | grep -oP "pid=\K\d+" | head -1)
      case $port in
        19993) svc="orchestrator" ;;
        19994) svc="storage-b" ;;
        19995) svc="storage-a" ;;
        19998) svc="tools-server" ;;
        19999) svc="gateway" ;;
      esac
      if [ -n "$pid" ]; then
        printf "  %-6s| %-7s| ✓ %s\n" "$port" "$pid" "$svc"
      else
        printf "  %-6s| %-7s| ✗ %s (DOWN)\n" "$port" "-" "$svc"
      fi
    done
    echo ""
    runtime_count=$(pgrep -f main_novaic.py 2>/dev/null | wc -l)
    echo "  Agent Runtime: $runtime_count 进程 (queue-service, watchdog, health, scheduler, 4×task-worker, 2×saga-worker)"
  '
  echo ""
  info "检查 relay 服务状态"
  $RELAY_SSH 'systemctl is-active novaic-quic-service && echo "  Relay: ✓ running" || echo "  Relay: ✗ stopped"'
}

check_logs() {
  local svc="${2:-gateway}"
  info "查看 $svc 最新日志"
  case "$svc" in
    gateway)      $API_SSH "tail -50 /opt/novaic/data/logs/gateway-\$(date +%Y%m%d).log" ;;
    orchestrator) $API_SSH "tail -50 /opt/novaic/data/logs/runtime-orchestrator.log" ;;
    tools)        $API_SSH "tail -50 /opt/novaic/data/logs/tools-server.log" ;;
    runtime)      $API_SSH "tail -50 /opt/novaic/data/logs/queue-service.log" ;;
    worker)       $API_SSH "tail -50 /opt/novaic/data/logs/task-worker-control-1.log" ;;
    relay)        $RELAY_SSH "journalctl -u novaic-quic-service --no-pager -n 50" ;;
    *)            fail "未知服务: $svc (可选: gateway, orchestrator, tools, runtime, worker, relay)" ;;
  esac
}

# ── 主入口 ────────────────────────────────────────────────────────────────────

show_help() {
  echo ""
  echo -e "${CYAN}NovAIC 部署工具${NC}"
  echo ""
  echo "用法: ./deploy <target> [option]"
  echo ""
  echo -e "${CYAN}客户端:${NC}"
  echo "  frontend [ver]    部署前端 OTA (默认 v0.3.0)"
  echo "  ios               构建并安装 iOS IPA"
  echo "  desktop           构建 macOS 桌面应用"
  echo ""
  echo -e "${CYAN}后端服务 (api.gradievo.com):${NC}"
  echo "  gateway           部署 Gateway (rsync + restart_gw.sh)"
  echo "  runtime           部署 Agent Runtime (rsync + 全部重启)"
  echo "  orchestrator      部署 Runtime Orchestrator (rsync + 全部重启)"
  echo "  tools             部署 Tools Server (rsync + 全部重启)"
  echo "  storage-a         部署 Storage A (rsync + 全部重启)"
  echo "  storage-b         部署 Storage B (rsync + 全部重启)"
  echo "  services          部署全部后端 (rsync all + start.sh 重启)"
  echo ""
  echo -e "${CYAN}基础设施:${NC}"
  echo "  relay             部署 QUIC/Relay 到 relay 服务器"
  echo ""
  echo -e "${CYAN}聚合 & 运维:${NC}"
  echo "  all [ver]         部署全部"
  echo "  status            检查所有服务状态"
  echo "  logs [svc]        查看日志 (gateway|orchestrator|tools|runtime|worker|relay)"
  echo ""
}

case "${1}" in
  frontend)     deploy_frontend "$2" ;;
  gateway)      deploy_gateway ;;
  runtime)      deploy_single_service "novaic-agent-runtime" ;;
  orchestrator) deploy_single_service "novaic-runtime-orchestrator" ;;
  tools)        deploy_single_service "novaic-tools-server" ;;
  storage-a)    deploy_single_service "novaic-storage-a" ;;
  storage-b)    deploy_single_service "novaic-storage-b" ;;
  services)     deploy_services ;;
  relay)        deploy_relay ;;
  ios)          deploy_ios ;;
  desktop)      deploy_desktop ;;
  all)          deploy_all "$2" ;;
  status)       check_status ;;
  logs)         check_logs "$@" ;;
  *)            show_help ;;
esac

