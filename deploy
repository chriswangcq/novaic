#!/bin/bash
# NovAIC 统一部署入口
# 用法: ./deploy <target> [options]
#
# 目标:
#   frontend [version]    部署前端 OTA 到 relay (默认 v0.3.0)
#   gateway               部署 Gateway 到 api.gradievo.com
#   relay                 部署 novaic-quic-service 到 relay
#   ios                   构建 iOS IPA 并安装到连接的设备
#   desktop               构建 macOS 桌面应用
#   all [version]         以上全部

set -e

# ── 配置 ──────────────────────────────────────────────────────────────────────
RELAY_HOST="47.243.221.45"
RELAY_PORT="52222"
RELAY_SSH="ssh -p $RELAY_PORT root@$RELAY_HOST"
API_HOST="root@api.gradievo.com"
VERSION="${2:-0.3.0}"
APP_DIR="$(cd "$(dirname "$0")" && pwd)/novaic-app"
GATEWAY_DIR="$(cd "$(dirname "$0")" && pwd)/novaic-gateway"
QUIC_DIR="$(cd "$(dirname "$0")" && pwd)/novaic-quic-service"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()  { echo -e "${CYAN}▸ $1${NC}"; }
ok()    { echo -e "${GREEN}✓ $1${NC}"; }
warn()  { echo -e "${YELLOW}⚠ $1${NC}"; }
fail()  { echo -e "${RED}✗ $1${NC}"; exit 1; }

# ── 部署函数 ──────────────────────────────────────────────────────────────────

deploy_frontend() {
  local ver="${1:-$VERSION}"
  info "部署前端 OTA (v${ver})"

  cd "$APP_DIR"
  info "构建前端..."
  VITE_BASE="/resource/frontend/v${ver}/" npm run build || fail "前端构建失败"

  info "上传到 relay..."
  $RELAY_SSH "mkdir -p /opt/novaic/static/v${ver}"
  rsync -avz --delete -e "ssh -p $RELAY_PORT" dist/ root@$RELAY_HOST:/opt/novaic/static/v${ver}/ || fail "rsync 失败"

  ok "前端 v${ver} 已部署到 https://relay.gradievo.com/resource/frontend/v${ver}/"
}

deploy_gateway() {
  info "部署 Gateway 到 api.gradievo.com"

  cd "$GATEWAY_DIR"
  info "同步代码..."
  rsync -avz --exclude '.git' --exclude '__pycache__' --exclude '*.pyc' \
    -e ssh . $API_HOST:/opt/novaic/services/novaic-gateway/ || fail "rsync 失败"

  info "重启 Gateway..."
  ssh $API_HOST 'bash /opt/novaic/restart_gw.sh' || fail "重启失败"

  info "验证..."
  sleep 2
  ssh $API_HOST 'ss -tlnp | grep 19999' && ok "Gateway 已部署并运行" || warn "端口 19999 未监听，请检查日志"
}

deploy_relay() {
  info "部署 novaic-quic-service 到 relay"

  cd "$QUIC_DIR"
  info "推送代码到 GitHub..."
  git add -A && git diff --cached --quiet || git commit -m "deploy: $(date +%Y-%m-%d)"
  git push origin main 2>/dev/null || true

  info "服务器拉取并编译（约 1-2 分钟）..."
  $RELAY_SSH 'cd /opt/novaic/novaic-quic-service && git pull origin main && cargo build --release && systemctl stop novaic-quic-service && cp target/release/novaic-quic-service ./ && systemctl start novaic-quic-service' || fail "编译或重启失败"

  info "验证..."
  $RELAY_SSH 'systemctl is-active novaic-quic-service' && ok "Relay 服务已部署" || warn "服务未运行"
}

deploy_ios() {
  info "构建 iOS IPA 并安装"

  cd "$APP_DIR"
  info "构建 IPA (export-method: debugging)..."
  npm run tauri ios build -- --export-method debugging || fail "iOS 构建失败"

  local IPA="src-tauri/gen/apple/build/arm64/NovAIC.ipa"
  [ -f "$IPA" ] || fail "IPA 文件不存在: $IPA"

  info "查找已连接设备..."
  local DEVICE=$(xcrun devicectl list devices 2>/dev/null | awk '/connected/ && !/Simulator/ {for(i=1;i<=NF;i++) if($i~/^[0-9A-F]{8}-/) {print $i;break}}' | head -1)

  if [ -z "$DEVICE" ]; then
    warn "未找到已连接设备，IPA 在: $IPA"
  else
    info "安装到设备 $DEVICE..."
    xcrun devicectl device install app --device "$DEVICE" "$IPA" || fail "安装失败"
    ok "iOS 应用已安装"
  fi
}

deploy_desktop() {
  info "构建 macOS 桌面应用"

  cd "$APP_DIR"
  npm run tauri:build -- --bundles app || fail "桌面构建失败"

  local APP="src-tauri/target/release/bundle/macos/NovAIC.app"
  [ -d "$APP" ] || fail "App 不存在: $APP"

  ok "桌面应用已构建: $APP"
  info "安装: cp -r '$APP' /Applications/NovAIC.app"
}

# ── 主入口 ────────────────────────────────────────────────────────────────────

show_help() {
  echo ""
  echo -e "${CYAN}NovAIC 部署工具${NC}"
  echo ""
  echo "用法: ./deploy <target> [version]"
  echo ""
  echo "目标:"
  echo "  frontend [ver]  部署前端 OTA (默认 v0.3.0)"
  echo "  gateway         部署 Gateway"
  echo "  relay           部署 QUIC/Relay 服务"
  echo "  ios             构建并安装 iOS IPA"
  echo "  desktop         构建 macOS 桌面应用"
  echo "  all [ver]       以上全部"
  echo ""
  echo "示例:"
  echo "  ./deploy frontend 0.3.1"
  echo "  ./deploy gateway"
  echo "  ./deploy all"
  echo ""
}

case "${1}" in
  frontend) deploy_frontend "$2" ;;
  gateway)  deploy_gateway ;;
  relay)    deploy_relay ;;
  ios)      deploy_ios ;;
  desktop)  deploy_desktop ;;
  all)
    deploy_frontend "$2"
    deploy_relay
    deploy_gateway
    deploy_ios
    deploy_desktop
    echo ""
    ok "全部部署完成！"
    ;;
  *)
    show_help
    ;;
esac
