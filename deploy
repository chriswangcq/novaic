rm -rf /opt/novaic/start.sh /opt/novaic/services /opt/novaic/novaic-quic-service /var/lib/redis /var/log/redis /etc/redis
systemctl daemon-reload
systemctl reset-failed redis-server coturn novaic-quic-service 2>/dev/null || true
{
  echo \"backup_dir=\$backup_dir\"
  echo \"runtime_coturn=$HOST_INFRA_RUNTIME_DIR/coturn/turnserver.conf\"
  echo \"runtime_redis=$HOST_INFRA_RUNTIME_DIR/redis\"
} > \"\$backup_dir/summary.txt\"" \
