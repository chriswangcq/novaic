# Copy to an untracked env file on the API host and pass it with:
#   docker compose --env-file /opt/novaic/llm-factory/prod/compose.env -f compose.yaml up -d

COMPOSE_PROJECT_NAME=novaic-llm-factory-prod
NOVAIC_NAMESPACE=prod
NOVAIC_RELEASE_ID=sha-local
NOVAIC_HOST_ID=api-host-1
NOVAIC_ENVIRONMENT=prod
NOVAIC_IMAGE_DIGEST=
NOVAIC_LLM_FACTORY_IMAGE=novaic/llm-factory:local
NOVAIC_LLM_FACTORY_BUILD_CONTEXT=./app
NOVAIC_LLM_FACTORY_RUNTIME_ENV=/opt/novaic/llm-factory/prod/runtime.env
NOVAIC_LLM_FACTORY_DATA_DIR=/opt/novaic/llm-factory/prod/data
NOVAIC_LLM_FACTORY_SECRETS_DIR=/opt/novaic/llm-factory/prod/secrets
NOVAIC_LLM_FACTORY_CONFIG=/data/config.json
NOVAIC_LLM_FACTORY_PORT=19990
NOVAIC_LLM_FACTORY_CONTAINER_PORT=19990
NOVAIC_POSTGRES_NETWORK=novaic-postgres_default
