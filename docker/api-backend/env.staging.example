# Example staging namespace env for docker/api-backend/compose.yaml.
# Copy to an untracked host env file; never commit real secrets.

COMPOSE_PROJECT_NAME=novaic-staging
NOVAIC_NAMESPACE=staging
NOVAIC_RELEASE_ID=sha-staging-sample
NOVAIC_HOST_ID=api-host-1
NOVAIC_ENVIRONMENT=staging
NOVAIC_IMAGE_DIGEST=sha256:staging-sample
NOVAIC_API_BACKEND_IMAGE=novaic/api-backend:sha-staging-sample
NOVAIC_DATA_DIR=/opt/novaic/data/staging
NOVAIC_SANDBOX_SHARED_DIR=/opt/novaic/data/staging/sandbox
NOVAIC_POSTGRES_SECRETS_DIR=/opt/novaic/postgres/secrets/staging
NOVAIC_ETC_DIR=/opt/novaic/etc/staging
NOVAIC_SERVICE_REGISTRY_URL=http://127.0.0.1:29991
NOVAIC_REGISTRY_TABLE=service_registry_instances
NOVAIC_REDIS_URL=redis://127.0.0.1:6379/1
NOVAIC_ENTANGLED_SERVICE_TOKEN_FILE=/opt/novaic/postgres/secrets/entangled_service_token

NOVAIC_PORT_BASE=29900
NOVAIC_ENTANGLED_PORT=29900
NOVAIC_RUNTIME_SCHEDULER_PORT=29983
NOVAIC_RUNTIME_HEALTH_PORT=29984
NOVAIC_SUBSCRIBER_PORT=29985
NOVAIC_REGISTRY_PORT=29991
NOVAIC_DEVICE_PORT=29993
NOVAIC_SANDBOX_PORT=29994
NOVAIC_BLOB_PORT=29995
NOVAIC_CORTEX_PORT=29996
NOVAIC_QUEUE_PORT=29997
NOVAIC_BUSINESS_PORT=29998
NOVAIC_GATEWAY_PORT=29999

NOVAIC_JWT_SECRET=replace-with-staging-jwt-secret
NOVAIC_CORTEX_INTERNAL_KEY=replace-with-staging-cortex-internal-key

NOVAIC_BLOB_BACKEND=oss
NOVAIC_OSS_ACCESS_KEY=replace-with-staging-access-key-id
NOVAIC_OSS_SECRET_KEY=replace-with-staging-access-key-secret
NOVAIC_OSS_ENDPOINT=https://oss-cn-hongkong.aliyuncs.com
NOVAIC_OSS_REGION=cn-hongkong
NOVAIC_OSS_BUCKET=replace-with-staging-bucket
