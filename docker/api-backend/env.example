# Copy to an untracked env file on the API host and pass it with:
#   docker compose --env-file /opt/novaic/docker/api-backend.env -f compose.yaml up -d

COMPOSE_PROJECT_NAME=novaic-prod
NOVAIC_NAMESPACE=prod
NOVAIC_RELEASE_ID=sha-local
NOVAIC_HOST_ID=api-host-1
NOVAIC_ENVIRONMENT=prod
NOVAIC_IMAGE_DIGEST=
NOVAIC_API_BACKEND_IMAGE=novaic/api-backend:local
NOVAIC_DATA_DIR=/opt/novaic/data/prod
NOVAIC_SANDBOX_SHARED_DIR=/opt/novaic/data/prod/sandbox
NOVAIC_POSTGRES_SECRETS_DIR=/opt/novaic/postgres/secrets/prod
NOVAIC_ETC_DIR=/opt/novaic/etc/prod
NOVAIC_SERVICE_REGISTRY_URL=http://127.0.0.1:19991
NOVAIC_REGISTRY_TABLE=service_registry_instances
NOVAIC_REDIS_URL=redis://127.0.0.1:6379/0
NOVAIC_ENTANGLED_SERVICE_TOKEN_FILE=/opt/novaic/postgres/secrets/entangled_service_token

NOVAIC_PORT_BASE=19900
NOVAIC_ENTANGLED_PORT=19900
NOVAIC_RUNTIME_SCHEDULER_PORT=19983
NOVAIC_RUNTIME_HEALTH_PORT=19984
NOVAIC_SUBSCRIBER_PORT=19985
NOVAIC_REGISTRY_PORT=19991
NOVAIC_DEVICE_PORT=19993
NOVAIC_SANDBOX_PORT=19994
NOVAIC_BLOB_PORT=19995
NOVAIC_CORTEX_PORT=19996
NOVAIC_QUEUE_PORT=19997
NOVAIC_BUSINESS_PORT=19998
NOVAIC_GATEWAY_PORT=19999

NOVAIC_JWT_SECRET=replace-with-deployed-jwt-secret
NOVAIC_CORTEX_INTERNAL_KEY=cortex-internal-dev

NOVAIC_BLOB_BACKEND=oss
NOVAIC_OSS_ACCESS_KEY=replace-with-access-key-id
NOVAIC_OSS_SECRET_KEY=replace-with-access-key-secret
NOVAIC_OSS_ENDPOINT=https://oss-cn-hongkong.aliyuncs.com
NOVAIC_OSS_REGION=cn-hongkong
NOVAIC_OSS_BUCKET=replace-with-bucket
