# Runtime env for /opt/novaic/docker/host-infra/compose.yaml.
# Real values are written to /opt/novaic/docker/host-infra.env by ./deploy host-infra.

NOVAIC_REDIS_IMAGE=redis:7-alpine
NOVAIC_COTURN_IMAGE=coturn/coturn:4.6.3
NOVAIC_QUIC_IMAGE=novaic/quic-service:local

NOVAIC_QUIC_GATEWAY_URL=https://api.gradievo.com
NOVAIC_QUIC_RELAY_PORT=443
NOVAIC_QUIC_STUN_PORT=3478
NOVAIC_QUIC_DISABLE_STUN=1
NOVAIC_QUIC_TLS_CERT_PATH=/etc/letsencrypt/live/relay.gradievo.com/fullchain.pem
NOVAIC_QUIC_TLS_KEY_PATH=/etc/letsencrypt/live/relay.gradievo.com/privkey.pem
NOVAIC_QUIC_RUST_LOG=info
