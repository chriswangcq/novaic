COMPOSE_PROJECT_NAME=novaic-release-controller
NOVAIC_RELEASE_CONTROLLER_IMAGE=127.0.0.1:5000/novaic/release-controller:sha-example
NOVAIC_RELEASE_CONTROLLER_PORT=19880
NOVAIC_RELEASE_CONTROLLER_CONFIG=/opt/novaic/release-controller/config.json
NOVAIC_RELEASE_CONTROLLER_CONFIG_HOST=/opt/novaic/release-controller/config.json
NOVAIC_RELEASE_CONTROLLER_STATE_DIR=/opt/novaic/release-controller/state
NOVAIC_RELEASES_DIR=/opt/novaic/releases
NOVAIC_RELEASE_CONTROLLER_WORKTREE=/opt/novaic/release-controller/worktree
NOVAIC_DOCKER_SOCKET=/var/run/docker.sock
